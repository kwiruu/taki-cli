{
  "name": "@kwiruu/taki-cli",
  "version": "0.1.0",
  "description": "A terminal multiplexer CLI for local development workflows.",
  "type": "module",
  "main": "dist/bin/cli.js",
  "bin": {
    "taki": "dist/bin/cli.js"
  },
  "scripts": {
    "dev": "tsx src/bin/cli.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/bin/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:check": "npm run build && npm run typecheck && npm run test && npm run pack:check",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run release:check"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kwiruu/taki-cli.git"
  },
  "homepage": "https://github.com/kwiruu/taki-cli#readme",
  "bugs": {
    "url": "https://github.com/kwiruu/taki-cli/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kwiruu"
  },
  "keywords": [
    "cli",
    "ink",
    "terminal",
    "task-runner",
    "multiplexer"
  ],
  "author": "kwiruu",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "tree-kill": "^1.2.2",
    "wrap-ansi": "^10.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
